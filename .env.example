WHITHER_ADDR=:8080
WHITHER_REDIS_URL=redis://localhost:6379/0
WHITHER_ENV=production                            # production | development
WHITHER_LOG_LEVEL=info                            # debug | info | warn | error

# Customization
WHITHER_USER_AGENT_CONTACT=contact@whither.link
WHITHER_ROOT_REDIRECT_TARGET=https://github.com/whither-link/whither

# Advanced
WHITHER_LOG_FORMAT=json                           # json | text
WHITHER_READ_HEADER_TIMEOUT=5s
WHITHER_READ_TIMEOUT=10s
WHITHER_WRITE_TIMEOUT=10s
WHITHER_IDLE_TIMEOUT=60s
WHITHER_SHUTDOWN_TIMEOUT=15s
WHITHER_UPSTREAM_TIMEOUT=10s
WHITHER_CACHE_TTL_POSITIVE=24h
WHITHER_CACHE_TTL_NEGATIVE=2h
WHITHER_CACHE_CONTROL_MAX_AGE=3600
WHITHER_RATE_LIMIT_RPS=10
WHITHER_RATE_LIMIT_BURST=20

# Cache tuning
WHITHER_REDIS_TIMEOUT=200ms
WHITHER_CACHE_LANG=en
WHITHER_CACHE_KEY_PREFIX=v1
WHITHER_CACHE_L1_ENABLED=false
WHITHER_CACHE_L1_SIZE=1024
WHITHER_CACHE_L1_TTL=60s
